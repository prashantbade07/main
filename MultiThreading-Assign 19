#Q1-Design a python application that creates two threads named Prime and NonPrime.
#Both threads should accept a list of integers
#The Prime threads should display all prime numbers from the list.
#The NonPrime thread should display all non prime numbers from list.
import threading

def ChkPrime(No):
    cnt=0
    prm=list()
    for i in range(len(No)):
        for j in range(1,No[i]+1):
            if No[i]%j==0:
                cnt=cnt+1
        if cnt==2:
            prm.append(No[i])
        cnt=0
    print("Prime number from list are:",prm)

def ChkNonPrime(No):
    cnt=0
    nonprm=list()
    for i in range(len(No)):
        for j in range(1,No[i]+1):
            if No[i]%j==0:
                cnt=cnt+1
        if cnt>2:
            nonprm.append(No[i])
        cnt=0
    print("Non Prime number from list are:",nonprm)

def main():
    val=int(input("Enter the number of elements:"))
    data=list()
    for i in range(val):
        a=int(input(f"Enter the {i+1} element:"))
        data.append(a)
    print(data)

    Prime=threading.Thread(target=ChkPrime,args=(data,))
    NonPrime=threading.Thread(target=ChkNonPrime,args=(data,))
    Prime.start()
    NonPrime.start()

    Prime.join()
    NonPrime.join()

if __name__=="__main__":
    main()

