#Q1-Write a program which accept N numbers from user and store it into list.Return addition of all elements from that list.

def add(no1):
    sum=0
    for i in no1:
        sum=sum+i
    return sum


def main():
    value=int(input("Enter the N number:"))
    data=list()
    for i in range(value):
        n=int(input())
        data.append(n)
    print(data)

    ret=add(data)
    print(f"Addition of {value} number:",ret)
     

if __name__=="__main__":
    main()
