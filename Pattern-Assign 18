#Q2-Write a program which accept and return factorial of number.
def fact(no1):
    prd=1
    for i in range(1,no1+1):
        prd=prd*i
    return prd

def main():
    value=int(input("Enter the name:"))
    Ret=fact(value)
    print(f"Factorial of {value} is:",Ret)
   
if __name__=="__main__":
    main()
