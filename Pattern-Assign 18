#Q3-Write a program which accept one number and check prime number or not.
def prime(No1):
    cnt=0
    for i in range(1,No1+1):
            if No1%i==0:
                cnt=cnt+1
    if cnt==2:
        return f"Prime number"
    else:
        return f"Not Prime number"

def main():
    value=int(input("Enter the number:"))
    Ret=prime(value)
    print(f"{value} is",Ret)
if __name__=="__main__":
    main()

