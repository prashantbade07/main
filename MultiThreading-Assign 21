#Q5-Design a python application that creates two threads named Thread1 and Thread2.
# Thread1 should display number from 1 to 50
#Thread2 should display number from 50 to 1 in reverse order.
#Ensure that
# Thread 2 start execution only after thread1 has completed
#Use appropriare thread synchronization

import threading
import os
def Ord():
    for i in range(1,51):
        print(i, end=" ")
    print("")
    print(f"Above is {threading.current_thread().name}")
  
def Rev():
    for i in range(50,0,-1):
        print(i,end=" ")
    print("")
    print(f"Above is {threading.current_thread().name}")

def main():

    threads=[ threading.Thread(target=Ord,name="Thread1"),
    threading.Thread(target=Rev,name="Thread2")]
    
    for t in threads:
        t.start()
        t.join()

if __name__=="__main__":
    main()
