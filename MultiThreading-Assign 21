#Q4-Design a Python application that creates three threads named Small,Capital and Digits.
#All threads should accept string as input
#The small thread should count and display the number of lowercase characters.
#The capital thread should count and display the number of uppercase characters.
#The digit thread should count and display the number of numeric digits
#Each thread must also display:
#Thread ID
#Thread Name

import threading
import os
def Small(no):
    cnt=0
    for i in range(len(no)):
        if no[i].islower()==True:
            cnt=cnt+1
    print("Number of lowercase characters:",cnt)
    print(f"Current thread name is:{threading.current_thread().name}")
    print("Thread Small ID:",threading.get_ident())

def Capital(no):
    cnt=0
    for i in range(len(no)):
        if no[i].isupper()==True:
            cnt=cnt+1
    print("Number of uppercase characters:",cnt)
    print(f"Current thread name is:{threading.current_thread().name}")
    print("Thread Cap ID:",threading.get_ident())

def Digits(no):
    cnt=0
    for i in range(len(no)):
        if no[i].isdigit()==True:
            cnt=cnt+1
    print("Number of digit characters:",cnt)
    print(f"Current thread name is:{threading.current_thread().name}")
    print("Thread Digi ID:",threading.get_ident())

def main():
    a=input("Enter the string:")
    print(a)

    t1=threading.Thread(target=Small,args=(a,),name="Small")

    t2=threading.Thread(target=Capital,args=(a,),name="Capital")

    t3=threading.Thread(target=Digits,args=(a,),name="Digits")

    t1.start()
    t2.start()
    t3.start()

    t1.join()
    t2.join()
    t3.join()

if __name__=="__main__":
    main()
